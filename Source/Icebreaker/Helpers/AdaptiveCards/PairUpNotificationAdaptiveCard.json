{
  "type": "AdaptiveCard",
  "body": [
    {
      "type": "Container",
      "items": [
        {
          "type": "TextBlock",
          "size": "Medium",
          "weight": "Bolder",
          "text": "${matchUpCardTitleContent}",
          "wrap": true,
          "maxLines": 2,
          "horizontalAlignment": "${textAlignment}"
        }
      ]
    },
    {
      "type": "Container",
      "items": [
        {
          "type": "Container",
          "items": [
            {
              "type": "TextBlock",
              "text": "${matchUpCardMatchedText}",
              "wrap": true,
              "horizontalAlignment": "${textAlignment}"
            }
          ]
        },
        {
          "type": "Container",
          "items": [
            {
              "type": "TextBlock",
              "text": "${matchUpCardContentPart1}",
              "wrap": true,
              "horizontalAlignment": "${textAlignment}"
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${matchUpCardContentPart2}",
          "wrap": true,
          "horizontalAlignment": "${textAlignment}"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "${changeFrequencyLabel}",
          "size": "Small",
          "isSubtle": true,
          "wrap": true
        },
        {
          "type": "ActionSet",
          "actions": [
            {
              "type": "Action.Submit",
              "title": "${frequencyWeeklyButtonText}",
              "style": "${frequencyWeeklyStyle}",
              "data": {
                "msteams": {
                  "type": "messageBack",
                  "displayText": "${frequencyWeeklyButtonText}",
                  "text": "frequency_weekly"
                }
              }
            },
            {
              "type": "Action.Submit",
              "title": "${frequencyBiweeklyButtonText}",
              "style": "${frequencyBiweeklyStyle}",
              "data": {
                "msteams": {
                  "type": "messageBack",
                  "displayText": "${frequencyBiweeklyButtonText}",
                  "text": "frequency_biweekly"
                }
              }
            },
            {
              "type": "Action.Submit",
              "title": "${frequencyMonthlyButtonText}",
              "style": "${frequencyMonthlyStyle}",
              "data": {
                "msteams": {
                  "type": "messageBack",
                  "displayText": "${frequencyMonthlyButtonText}",
                  "text": "frequency_monthly"
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "${chatWithMatchButtonText}",
      "url": "https://teams.microsoft.com/l/chat/0/0?users=${personUpn}&message=${chatWithMessageGreeting}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "${proposeMeetupButtonText}",
      "url": "${meetingLink}"
    },
    {
      "type": "Action.Submit",
      "title": "${pauseMatchesButtonText}",
      "data": {
        "msteams": {
          "type": "messageBack",
          "displayText": "${pauseMatchesButtonText}",
          "text": "optout"
        }
      }
    }
  ],
  "version": "1.2"
}
